{
  "name": "opr-hex-generator",
  "version": "1.0.0",
  "description": "OPR Hex Battle Map Generator - Procedurally generated hex maps for One Page Rules",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "keywords": [
    "opr",
    "hexmap",
    "wargame",
    "tabletop"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "preact": "^10.28.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.9.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}
